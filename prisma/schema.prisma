generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  JUSTIFIED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher  Teacher?
  accounts Account[]
  sessions Session[]
  reports  Report[]
}

model Teacher {
  id                 String        @id @default(cuid())
  userId             String        @unique
  firstName          String
  lastName           String
  fullName           String
  dni                String?
  status             TeacherStatus @default(ACTIVE)
  assignedGradeId   String?
  assignedSectionId String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedGrade     Grade?             @relation("TeacherAssignedGrade", fields: [assignedGradeId], references: [id])
  assignedSection   Section?           @relation("TeacherAssignedSection", fields: [assignedSectionId], references: [id])
  courses           Course[]
  gradeRecords      GradeRecord[]
  attendances       Attendance[]
  learningSessions  LearningSession[]
  generatedSessions GeneratedSession[]
}

model Grade {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections         Section[]
  students         Student[]
  courses          Course[]
  teachersAssigned Teacher[] @relation("TeacherAssignedGrade")
}

model Section {
  id        String   @id @default(cuid())
  name      String
  gradeId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grade            Grade        @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  students         Student[]
  courses          Course[]
  attendance       Attendance[]
  teachersAssigned Teacher[]   @relation("TeacherAssignedSection")

  @@unique([gradeId, name])
}

model Course {
  id        String   @id @default(cuid())
  name      String
  gradeId   String
  sectionId String
  teacherId String
  periodId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grade      Grade          @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  section    Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher    Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  period     AcademicPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  gradeItems GradeRecord[]

  @@unique([name, sectionId, periodId])
}

model AcademicPeriod {
  id        String   @id @default(cuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]
}

model Student {
  id              String        @id @default(cuid())
  code            String        @unique
  firstName       String
  lastName        String
  fullName        String
  dni             String?
  birthDate       DateTime?
  guardian        String?
  guardianPhone   String?
  address         String?
  gradeId         String
  sectionId       String
  status          StudentStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  grade        Grade         @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  section      Section       @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  attendance   Attendance[]
  gradeRecords GradeRecord[]
}

model Attendance {
  id            String           @id @default(cuid())
  date          DateTime
  status        AttendanceStatus
  justification String?
  studentId     String
  sectionId     String
  teacherId     String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([date, studentId])
}

model GradeRecord {
  id        String   @id @default(cuid())
  note1     Float
  note2     Float
  note3     Float
  studentId String
  courseId  String
  area      String
  teacherId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model LearningSession {
  id               String   @id @default(cuid())
  title            String
  grade            String
  section          String   @default("")
  area             String
  competence       String
  capacity         String
  performance      String
  learningPurpose  String
  learningEvidence String
  startActivity      String
  development      String
  closure          String
  resources        String
  evaluation       String
  date             DateTime
  duration         String   @default("90 minutos")
  generatedByIa    Boolean  @default(false)
  teacherId        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model GeneratedSession {
  id         String   @id @default(cuid())
  grade      String
  area       String
  topic      String
  competence String
  duration   String
  purpose    String
  content    Json
  teacherId  String
  createdAt  DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id               String   @id @default("default")
  institutionName  String   @default("I.E. Virgen del Carmen")
  modularCode      String?
  address          String?
  district         String?
  province         String?
  region           String?
  academicYear     String?
  directorName     String?
  logoUrl          String?
  primaryColor     String?  @default("#0B1F3A")
  secondaryColor   String?  @default("#0F4C81")
  accentColor      String?  @default("#F2B705")
  periodsJson      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  reportType  String
  title       String
  meta        Json?
  createdById String
  createdAt   DateTime @default(now())

  user User @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AgentLog {
  id        String   @id @default(cuid())
  agentName String
  input     String
  output    String
  userId    String?
  createdAt DateTime @default(now())
}
